# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL - Railway)
DATABASE_URL=postgresql://user:password@host:5432/clip_factory

# Dashboard
DASHBOARD_PASSWORD=changeme
SESSION_SECRET=troque-por-string-aleatoria-longa

# Temp directory for video files
TEMP_DIR=./tmp

# AssemblyAI (Story 4.3)
ASSEMBLYAI_API_KEY=

# OpenAI (Story 4.4)
OPENAI_API_KEY=

# YouTube OAuth (Story 4.7)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://your-railway-domain/auth/youtube/callback

# Encriptação de tokens OAuth (Story 5.1) — OBRIGATÓRIO, mínimo 32 caracteres
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Redis — fila de tarefas BullMQ (Story 5.4) — OBRIGATÓRIO
# Dev local: docker run -d -p 6379:6379 redis:alpine
# Railway: adicionar Redis add-on e copiar a URL
REDIS_URL=redis://localhost:6379

# Transcription language (default: pt)
TRANSCRIPTION_LANGUAGE=pt

# Circuit Breaker — proteção da YouTube API (Story 8.2)
# Número de falhas consecutivas para abrir o circuit (default: 5)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# Tempo em ms que o circuit permanece OPEN antes de tentar HALF_OPEN (default: 300000 = 5min)
CIRCUIT_BREAKER_OPEN_DURATION_MS=300000
# Delay em ms para reagendar uploads quando circuit está OPEN (default: 60000 = 1min)
CIRCUIT_BREAKER_RETRY_DELAY_MS=60000
